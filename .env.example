# Tradesman Ledger Environment Configuration
# Copy this file to .env.development and .env.production
# NEVER commit actual .env files to version control

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
AUTH_REDIRECT_URL=tradesmanledger://login-callback/

# AI Service Keys
DEEPGRAM_API_KEY=your_deepgram_key_here
GOOGLE_GEMINI_KEY=your_gemini_key_here

# App Configuration
APP_ENV=development
APP_NAME=Tradesman Ledger
APP_VERSION=1.0.0

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_PRO_FEATURES=true
